rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(roleName) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == roleName;
    }

    function isAdminOrOwner() {
      return isSignedIn() && (
        (request.auth.token != null && 'email' in request.auth.token && request.auth.token.email == 'mr.vishnu4321@gmail.com') ||
        hasRole('Admin') || 
        hasRole('Owner')
      );
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (
        isOwner(userId) || isAdminOrOwner()
      );
      allow delete: if isAdminOrOwner();
    }

    // Songs collection
    match /songs/{songId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    // Albums
    match /albums/{albumId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    // Artists
    match /artists/{artistId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    // Playlists
    match /playlists/{playlistId} {
      allow read: if resource == null || resource.data.isPublic == true || isOwner(resource.data.ownerId);
      allow create: if isSignedIn() && isOwner(request.resource.data.ownerId);
      allow update: if isSignedIn() && (isOwner(resource.data.ownerId) || isAdminOrOwner());
      allow delete: if isSignedIn() && (isOwner(resource.data.ownerId) || isAdminOrOwner());
    }

    // Favorites
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // History
    match /history/{historyId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdminOrOwner());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdminOrOwner() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Activity logs
    match /activity_logs/{logId} {
      allow read: if isAdminOrOwner();
      allow create: if true;
    }

    // AdConfig
    match /adConfig/{configId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    // HomepageConfig
    match /homepageConfig/{configId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if isAdminOrOwner() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdminOrOwner();
    }

    // Coupons collection
    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrOwner();
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminOrOwner());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminOrOwner());
    }

    // Comments collection
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminOrOwner());
    }

    // Chat messages collection
    match /chat_messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdminOrOwner();
    }

    // Feedback collection
    match /feedback/{feedbackId} {
      allow read: if isAdminOrOwner();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdminOrOwner();
    }
  }
}
